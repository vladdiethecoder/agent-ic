{
  "name": "agent-ic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Agent IC: enterprise control plane for buying agentic services with bounded Stripe test-mode spend, policy gates, workload evidence, and expansion decisions.",
  "scripts": {
    "dev": "node scripts/safe-next.mjs dev",
    "build": "node scripts/safe-next.mjs build",
    "start": "node scripts/safe-next.mjs start",
    "dev:local": "next dev",
    "build:local": "next build",
    "start:local": "next start",
    "lint": "eslint \"**/*.{js,mjs,jsx}\"",
    "test": "AGENT_IC_AUDIT_FILE=.agent-ic/test-audit-log.jsonl node --test tests/*.test.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:api": "node scripts/api-edge-smoke.mjs",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "proof:hermes": "node scripts/agent-ic-proof.mjs proof hermes",
    "proof:stripe": "node scripts/agent-ic-proof.mjs proof stripe",
    "proof:nemotron": "node scripts/agent-ic-proof.mjs proof nemotron",
    "proof:policy": "node scripts/agent-ic-proof.mjs proof policy",
    "proof:playbook": "node scripts/agent-ic-proof.mjs proof playbook",
    "proof:rerun": "node scripts/agent-ic-proof.mjs proof rerun",
    "demo:voice": "bash scripts/make-voiceover.sh",
    "demo:record": "node scripts/record-live-demo.mjs",
    "demo:post-produce": "node scripts/post-produce-final.mjs",
    "demo:qa": "node scripts/video-qa-final.mjs",
    "demo:frame-qa": "AGENT_IC_REQUIRE_VISION_FRAME_QA=false node scripts/frame-review-final.mjs",
    "demo:frame-qa:vision": "AGENT_IC_REQUIRE_VISION_FRAME_QA=true AGENT_IC_FRAME_QA_ALLOW_NO_LLM=false OPENAI_COMPAT_BASE_URL=${OPENAI_COMPAT_BASE_URL:-http://127.0.0.1:11434/v1} OPENAI_COMPAT_API_KEY=${OPENAI_COMPAT_API_KEY:-ollama} OPENAI_COMPAT_MODEL=${OPENAI_COMPAT_MODEL:-gemma4:12b} AGENT_IC_FRAME_REVIEW_MAX_SHEETS=${AGENT_IC_FRAME_REVIEW_MAX_SHEETS:-1} node scripts/frame-review-final.mjs",
    "demo:chatgpt55-20": "node scripts/chatgpt55-review-final.mjs",
    "demo:chatgpt55-20:goals": "AGENT_IC_CHATGPT55_REVIEW_SUITE=overarching AGENT_IC_CHATGPT55_REVIEW_DIR=demo-out/chatgpt55-reviews/overarching-20 AGENT_IC_CHATGPT55_REVIEW_REPORT=demo-out/chatgpt55-reviews/overarching-20-report.json node scripts/chatgpt55-review-final.mjs",
    "demo:chatgpt55-10:product": "AGENT_IC_CHATGPT55_REVIEW_SUITE=product AGENT_IC_CHATGPT55_REVIEW_DIR=demo-out/chatgpt55-reviews/product-10 AGENT_IC_CHATGPT55_REVIEW_REPORT=demo-out/chatgpt55-reviews/product-10-report.json node scripts/chatgpt55-review-final.mjs",
    "demo:hermes-20": "AGENT_IC_REVIEW_PROVIDER=hermes AGENT_IC_CHATGPT55_REVIEW_DIR=demo-out/hermes-reviews/final-20 AGENT_IC_CHATGPT55_REVIEW_REPORT=demo-out/hermes-reviews/final-20-report.json node scripts/chatgpt55-review-final.mjs",
    "demo:hermes-20:goals": "AGENT_IC_REVIEW_PROVIDER=hermes AGENT_IC_CHATGPT55_REVIEW_SUITE=overarching AGENT_IC_CHATGPT55_REVIEW_DIR=demo-out/hermes-reviews/overarching-20 AGENT_IC_CHATGPT55_REVIEW_REPORT=demo-out/hermes-reviews/overarching-20-report.json node scripts/chatgpt55-review-final.mjs",
    "demo:hermes-10:product": "AGENT_IC_REVIEW_PROVIDER=hermes AGENT_IC_CHATGPT55_REVIEW_SUITE=product AGENT_IC_CHATGPT55_REVIEW_DIR=demo-out/hermes-reviews/product-10 AGENT_IC_CHATGPT55_REVIEW_REPORT=demo-out/hermes-reviews/product-10-report.json node scripts/chatgpt55-review-final.mjs",
    "demo:hermes-50": "npm run demo:hermes-20 && npm run demo:hermes-20:goals && npm run demo:hermes-10:product",
    "demo:record:v18": "node scripts/record-v18-demo.mjs",
    "demo:voice:v18": "VOICEOVER_TXT=demo/voiceover-v18.txt VOICEOVER_WAV=demo-out/agent-ic-audio-v18.wav VOICEOVER_TIMING_JSON=demo-out/caption-timing-v18.json VOICEOVER_SEGMENT_DIR=demo-out/voiceover-segments-v18 node scripts/build-captioned-voiceover.mjs",
    "demo:mux:v18": "node scripts/mux-v18-demo.mjs",
    "demo:video:v18": "npm run demo:voice:v18 && npm run demo:record:v18 && npm run demo:mux:v18",
    "demo:inspect": "ffprobe -show_streams demo-out/agent-ic-demo-final.mp4"
  },
  "dependencies": {
    "next": "^15.5.19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "tesseract.js": "^7.0.0"
  }
}
