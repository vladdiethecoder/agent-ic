# Agent IC optional live integrations. The app runs fully in DEMO_MODE without these.

# NVIDIA NIM / Nemotron OpenAI-compatible endpoint.
# Official NIM LLM exposes POST /v1/chat/completions on the configured base URL.
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_API_KEY=nvapi-...
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b

# Optional Hermes handoff endpoint/webhook if running a local/gateway Hermes API bridge.
# Leave blank for deterministic in-app evaluator.
# Aliases: HERMES_GATEWAY_URL or HERMES_WEBHOOK_URL (both fall back to HERMES_AGENT_URL).
# When live, Agent IC requests these official Hermes payment skills from the catalog:
#   official/payments/stripe-link-cli
#   official/payments/stripe-projects
#   official/payments/mpp-agent
# See https://hermes-agent.nousresearch.com/docs/reference/optional-skills-catalog#payments
HERMES_AGENT_URL=http://localhost:8080/webhooks/agent-ic-evaluate
HERMES_AGENT_TOKEN=

# Stripe live path. If absent, /api/stripe-session returns a mock Checkout result.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: poll Stripe Checkout Session payment status in /api/run-capital-experiment-v8.
AGENT_IC_STRIPE_POLL_PAYMENT=true

# NemoClaw / OpenShell local policy proxy. If absent, blocked-action events are deterministic replays.
# Quickstart: `nemohermes onboard` creates a Hermes sandbox with an OpenAI-compatible API at
# http://127.0.0.1:8642/v1 and applies a baseline policy + network policy tier.
# See https://docs.nvidia.com/nemoclaw/latest/user-guide/hermes/get-started/quickstart
# Aliases: OPENSHELL_COMMAND or NEMOCLAW_POLICY_MODE (both fall back to NEMOCLAW_PROXY_URL).
NEMOCLAW_PROXY_URL=http://localhost:9000

# Public app URL (used for Stripe webhooks and redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Use demo mode by default to prevent accidental spend or model calls.
AGENT_IC_DEMO_MODE=true
