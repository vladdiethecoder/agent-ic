# Agent IC local configuration template.
# Copy to .env.local and replace placeholders with real credentials for the integrations you intend to use.
# Never commit .env.local.

# NVIDIA NIM / Nemotron OpenAI-compatible endpoint.
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_API_KEY=nvapi-...
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b

# Hermes dispatch options. Enable exactly one live path when you want a per-run Hermes receipt.
HERMES_AGENT_URL=
HERMES_AGENT_TOKEN=
AGENT_IC_HERMES_CLI_LIVE=false
HERMES_BIN=/home/vdubrov/.local/bin/hermes
AGENT_IC_HERMES_TIMEOUT_SECONDS=90
AGENT_IC_HERMES_NEMOHERMES_LIVE=false
AGENT_IC_HERMES_NEMOHERMES_SANDBOX=agent-ic-hermes

# Stripe Checkout. sk_test keys produce non-production Checkout receipts; production claims require approved live-mode setup.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
AGENT_IC_STRIPE_POLL_PAYMENT=true

# OpenShell / policy enforcement.
# OpenShell CLI is used directly when installed; proxy settings are optional.
OPENSHELL_BINARY=/usr/bin/openshell
NEMOCLAW_PROXY_URL=
AGENT_IC_NEMOCLAW_EXTERNAL_LIVE=false
AGENT_IC_NEMOHERMES_SANDBOX=agent-ic-hermes

# Public app URL used for provider redirects/webhooks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local provider-off mode prevents outbound provider calls. Set false for real local integration receipts.
AGENT_IC_LOCAL_MODE=false

# Production mode requires authenticated principals and approved spend before trial execution.
AGENT_IC_PRODUCTION_MODE=false
AGENT_IC_DEPLOYMENT_MODE=development
AGENT_IC_REQUIRE_LIVE_PROOF=false   # production deployments should set true

# Enterprise identity lifecycle / SCIM provisioning.
AGENT_IC_SCIM_BEARER_TOKEN=replace-me-scim-token
AGENT_IC_SCIM_TENANT_ID=local-tenant

# Audit integrity. Production should rotate and store this in a secret manager.
AGENT_IC_AUDIT_SIGNING_KEY=replace-me-audit-signing-key
AGENT_IC_AUDIT_SIGNING_KEY_ID=default
AGENT_IC_AUDIT_REQUIRE_SIGNATURES=false

# External observability export foundation. Use HTTPS in production.
AGENT_IC_TELEMETRY_EXPORT_URL=https://telemetry.example.com/agent-ic
AGENT_IC_TELEMETRY_EXPORT_TOKEN=replace-me-telemetry-token
AGENT_IC_TELEMETRY_EXPORT_TIMEOUT_MS=8000
